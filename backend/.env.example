# Server
PORT=5000
NODE_ENV=development
JWT_SECRET=super_secret_jwt_key_change_in_production
LOG_LEVEL=debug

# Stellar network configurations
STELLAR_NETWORK=TESTNET
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ADDRESS=CDXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SERVICE_WALLET_ADDRESS=GDXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SERVICE_PRIVATE_KEY=SDXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# PostgreSQL Database url
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/usagepay
DB_POOL_SIZE=20

# Third-party integrations
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FREIGHTER_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Billing Settings
COST_PER_SUMMARY_STROOPS=5000000 # 0.5 XLM
AUTO_TOPUP_CHECK_INTERVAL=3600
RECONCILIATION_INTERVAL=3600

# Sentry Monitoring (Optional in development)
SENTRY_DSN=
